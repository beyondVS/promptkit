# ==========================================
# PromptKit .gitignore configuration
# Matches: Python, Windows, macOS, PyCharm, Django, uv
# ==========================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- PyCharm / IntelliJ ---
.idea/
*.iml
*.iws
out/
.navigation/

# --- Windows ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.sys
*.tmp

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.Spotlight-V100
.Trashes
VolumeIcon.icns
.com.apple.timemachine.donotbackup
.fseventsd

# --- Virtual Environments (uv, virtualenv, venv) ---
.venv/
venv/
ENV/
env/
ActiveState.venv/

# --- Static Analysis / Testing tools ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.nosetests
nosetests.xml
pylintrec
.tox/
.dmypy.json
dmypy.json

# --- Security & Secrets ---
.env
*.env
.secrets
secrets.json

# --- Django Specific ---
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
celerybeat-schedule
